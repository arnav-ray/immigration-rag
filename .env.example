# immigration-rag — environment configuration template
# Copy this file to .env and adjust as needed.
# .env is git-ignored; never commit real values.

# ── LLM (served via Ollama) ────────────────────────────────────────────────────
LLM_MODEL=qwen2.5:14b
LLM_REQUEST_TIMEOUT=300.0
LLM_NUM_CTX=8192

# Model used at index-build time (build_db.py)
BUILD_LLM_MODEL=mistral-nemo:12b
BUILD_LLM_TIMEOUT=120.0
BUILD_LLM_NUM_CTX=16384

# ── Embedding & reranker ────────────────────────────────────────────────────────
EMBED_MODEL=nomic-embed-text-v2-moe
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_MAX_LEN=512

# ── Retrieval ───────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5

# ── File paths ──────────────────────────────────────────────────────────────────
PERSIST_DIR=./data_vector_store
DATA_INPUT_DIR=data_input
DATA_OUTPUT_DIR=data_output

# ── Input safety ────────────────────────────────────────────────────────────────
MAX_QUERY_LEN=2000
MAX_HISTORY_TURN_LEN=4000
MAX_HISTORY_TURNS=6

# ── Logging ─────────────────────────────────────────────────────────────────────
LOG_FILE=rag_audit.log
# LOG_LEVEL options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
